\NewDocumentCommand{\PageDeGardeIHEDN}{g}{%
\begingroup
\ifcoverfontlocal
  \CoverSetupMainFont
\fi
\CoverApplyTypesettingFreeze
\ifcoverlocalsmallcapsfix
  \CoverApplySmallCapsFix
\fi
\ifcoverapplygeometry
  \newgeometry{
    paperwidth=595.32001bp,
    paperheight=841.92004bp,
    margin=0pt
  }%
\fi
\IfNoValueTF{#1}{\CoverSetFields{}}{\CoverSetFields{#1}}
\begin{titlepage}
\thispagestyle{empty}
\begin{tikzpicture}[remember picture,overlay]

% Reference dimensions (from reference.pdf):
% MediaBox: 595.320pt x 841.920pt = 210.000mm x 297.000mm
% 1pt = 0.3527778mm

% --- Logo ---
\CoverPlaceLogoIfSet

% --- Header (from measured line boxes) ---
\CoverLineBoxRight{\CoverXRight}{\CoverHeaderLineOneY}{\bfseries\fontsize{15.333pt}{18.000pt}\selectfont}{\CoverHeaderOneField}
\CoverLineBoxRight{\CoverXRight}{\CoverHeaderLineTwoY}{\bfseries\fontsize{15.333pt}{18.000pt}\selectfont}{\CoverHeaderTwoField}
\CoverLineBoxRight{\CoverXRight}{\CoverHeaderLineThreeY}{\bfseries\fontsize{15.333pt}{18.000pt}\selectfont}{\CoverHeaderThreeField}
\CoverLineBoxRight{\CoverXRight}{\CoverHeaderDateY}{\bfseries\itshape\fontsize{15.333pt}{18.000pt}\selectfont}{\CoverDateField}

% --- Main title ---
\CoverTitleBox{\CoverTitleField}

% --- Subtitle ---
\CoverLineBox{\CoverReportLineOneX}{\CoverReportLineOneY}{\bfseries\itshape\fontsize{15.333pt}{18.000pt}\selectfont}{\CoverReportLineOneWidth}{c}{\CoverReportLineOneField}
\CoverLineBox{\CoverReportLineTwoX}{\CoverReportLineTwoY}{\bfseries\itshape\fontsize{15.333pt}{18.000pt}\selectfont}{\CoverReportLineTwoWidth}{c}{\CoverReportLineTwoField}

% --- Central statement ---
\CoverSubtitleBox{\CoverSubtitleField}

% --- Committee paragraph ---
\CoverCommitteeBoxJustified{\CoverCommitteeX}{\CoverCommitteeY}{\CoverCommitteeWidth}{\CoverCommitteeFontSpec}{\CoverCommitteeField}

\ifcoverdebug
  % 1 mm grid + emphasized 10 mm grid
  \foreach \x in {0,1,...,210} {
    \draw[gray!18,line width=0.03mm] ([xshift=\x mm]current page.north west) -- ([xshift=\x mm,yshift=-297mm]current page.north west);
  }
  \foreach \y in {0,1,...,297} {
    \draw[gray!18,line width=0.03mm] ([yshift=-\y mm]current page.north west) -- ([xshift=210mm,yshift=-\y mm]current page.north west);
  }
  \foreach \x in {0,10,...,210} {
    \draw[gray!55,line width=0.09mm] ([xshift=\x mm]current page.north west) -- ([xshift=\x mm,yshift=-297mm]current page.north west);
  }
  \foreach \y in {0,10,...,297} {
    \draw[gray!55,line width=0.09mm] ([yshift=-\y mm]current page.north west) -- ([xshift=210mm,yshift=-\y mm]current page.north west);
  }
  \draw[red!85!black,line width=0.20mm]
    ([xshift=\CoverXRight mm]current page.north west) --
    ([xshift=\CoverXRight mm,yshift=-297mm]current page.north west);
  \node[anchor=north west,inner sep=0.3mm,font=\tiny\ttfamily,fill=white]
    at ([xshift=\CoverXRight mm,yshift=-0.8mm]current page.north west) {X\_RIGHT};

  % Bounding boxes
  \CoverDebugLogoBoxIfSet
  \CoverDebugBox{\CoverDebugHeaderOneX}{\CoverHeaderLineOneY}{\CoverDebugHeaderOneWidth}{\CoverDebugLineHeight}{hdr1}
  \CoverDebugBox{\CoverDebugHeaderTwoX}{\CoverHeaderLineTwoY}{\CoverDebugHeaderTwoWidth}{\CoverDebugLineHeight}{hdr2}
  \CoverDebugBox{\CoverDebugHeaderThreeX}{\CoverHeaderLineThreeY}{\CoverDebugHeaderThreeWidth}{\CoverDebugLineHeight}{hdr3}
  \CoverDebugBox{\CoverDebugHeaderDateX}{\CoverHeaderDateY}{\CoverDebugHeaderDateWidth}{\CoverDebugLineHeight}{date}
  \CoverDebugBox{\CoverTitleX}{\CoverTitleY}{\CoverTitleWidth}{\CoverDebugTitleHeight}{title}
  \CoverDebugBox{\CoverReportLineOneX}{\CoverReportLineOneY}{\CoverReportLineOneWidth}{\CoverDebugSubtitleReportOneHeight}{sub1}
  \CoverDebugBox{\CoverReportLineTwoX}{\CoverReportLineTwoY}{\CoverReportLineTwoWidth}{\CoverDebugSubtitleReportTwoHeight}{sub2}
  \CoverDebugBox{\CoverSubtitleBlockX}{\CoverSubtitleBlockY}{\CoverSubtitleBlockWidth}{\CoverDebugSubtitleBlockHeight}{subtitle-block}
  \CoverDebugBox{\CoverCommitteeX}{\CoverCommitteeY}{\CoverCommitteeWidth}{\CoverDebugCommitteeHeight}{committee-block}
  \draw[orange!90!black,line width=0.18mm]
    ([xshift=\dimexpr\CoverCommitteeX mm + \CoverCommitteeWidth mm/2\relax,yshift=-\CoverCommitteeY mm]current page.north west) --
    ([xshift=\dimexpr\CoverCommitteeX mm + \CoverCommitteeWidth mm/2\relax,yshift=-\CoverCommitteeBottomY mm]current page.north west);
  \node[anchor=south west,inner sep=0.3mm,font=\tiny\ttfamily,fill=white]
    at ([xshift=\dimexpr\CoverCommitteeX mm + \CoverCommitteeWidth mm/2\relax,yshift=-\CoverCommitteeBottomY mm]current page.north west) {committee-center};
  \draw[magenta!85!black,line width=0.18mm]
    ([xshift=\dimexpr\CoverCommitteeX mm + \CoverCommitteeWidth mm\relax,yshift=-\CoverCommitteeY mm]current page.north west) --
    ([xshift=\dimexpr\CoverCommitteeX mm + \CoverCommitteeWidth mm\relax,yshift=-\CoverCommitteeBottomY mm]current page.north west);
  \node[anchor=south east,inner sep=0.3mm,font=\tiny\ttfamily,fill=white]
    at ([xshift=\dimexpr\CoverCommitteeX mm + \CoverCommitteeWidth mm\relax,yshift=-\CoverCommitteeBottomY mm]current page.north west) {committee-right};
\fi

\end{tikzpicture}
