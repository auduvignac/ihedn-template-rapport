\newcommand{\CoverLine}[4]{%
  \node[
    anchor=north west,
    inner sep=0pt,
    outer sep=0pt
  ] at ([xshift=#1mm,yshift=-#2mm]current page.north west) {{#3\mbox{#4}}};%
}

\newcommand{\CoverLineBox}[6]{%
  \node[
    anchor=north west,
    inner sep=0pt,
    outer sep=0pt
  ] at ([xshift=#1mm,yshift=-#2mm]current page.north west) {{#3\makebox[#4mm][#5]{#6}}};%
}

\newcommand{\CoverLineBoxRight}[4]{%
  \node[
    anchor=north east,
    inner sep=0pt,
    outer sep=0pt
  ] at ([xshift=#1mm,yshift=-#2mm]current page.north west) {{#3\mbox{#4}}};%
}

\newcommand{\CoverTextBox}[6]{%
  \node[
    anchor=north west,
    inner sep=0pt,
    outer sep=0pt,
    text width=#3mm,
    align=#4
  ] at ([xshift=#1mm,yshift=-#2mm]current page.north west) {{#5#6}};%
}

\newcommand{\CoverTitleBox}[1]{%
  \CoverTextBox{\CoverTitleX}{\CoverTitleY}{\CoverTitleWidth}{center}{\bfseries\CoverTitleFontSpec}{#1}%
}

\newcommand{\CoverSubtitleBox}[1]{%
  \CoverTextBox{\CoverSubtitleBlockX}{\CoverSubtitleBlockY}{\CoverSubtitleBlockWidth}{center}{\bfseries\CoverSubtitleFontSpec}{#1}%
}

\newcommand{\CoverCommitteeBoxJustified}[5]{%
  \node[
    anchor=north,
    inner sep=0pt,
    outer sep=0pt
  ] at ([xshift=\dimexpr#1mm + #3mm/2\relax,yshift=-#2mm]current page.north west)
    {{#4\parbox[t]{#3mm}{%
      \setlength{\parindent}{0pt}%
      \setlength{\parskip}{0pt}%
      \leftskip=0pt%
      \rightskip=0pt%
      \parfillskip=0pt%
      \justifying\noindent #5%
    }}};%
}

\newcommand{\CoverPlaceImage}[5]{%
  \node[anchor=north west,inner sep=0pt,outer sep=0pt]
    at ([xshift=#1mm,yshift=-#2mm]current page.north west)
    {\includegraphics[width=#3mm,height=#4mm]{#5}};%
}

\newcommand{\CoverPlaceSvg}[5]{%
  \ifcoverusesvg
    \node[anchor=north west,inner sep=0pt,outer sep=0pt]
      at ([xshift=#1mm,yshift=-#2mm]current page.north west)
      {\includesvg[width=#3mm,height=#4mm,inkscapelatex=false]{#5}};%
  \else
    \PackageWarningNoLine{ihedn-cover}{%
      SVG~logo~requested~('#5')~but~svg~support~is~disabled~(option~no-svg-support)%
    }%
  \fi
}

\newcommand{\CoverDebugBox}[5]{%
  \draw[cyan!70!black,line width=0.15mm]
    ([xshift=#1mm,yshift=-#2mm]current page.north west)
    rectangle ++(#3mm,-#4mm);
  \node[anchor=south west,inner sep=0.3mm,font=\tiny\ttfamily,fill=white]
    at ([xshift=#1mm,yshift=-#2mm]current page.north west) {#5};
}

