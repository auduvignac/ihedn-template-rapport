\newcommand{\CoverApplyTypesettingFreeze}{%
  % Typographic freeze: no microtype, fixed spacing behavior.
  \frenchspacing
  \linespread{1}\selectfont
  \hyphenpenalty=10000
  \exhyphenpenalty=10000
  \tolerance=1
  \emergencystretch=0pt
  \setlength{\parindent}{0pt}
  \setlength{\parskip}{0pt}
}

% Font setup target: Times New Roman (XeLaTeX).
\newcommand{\CoverFontFallbackNote}{}
\newcommand{\CoverSetupMainFont}{%
  \IfFontExistsTF{Times New Roman}{%
    \setmainfont{Times New Roman}[
      UprightFont = *,
      BoldFont = * Bold,
      ItalicFont = * Italic,
      BoldItalicFont = * Bold Italic
    ]%
  }{%
    \PackageWarningNoLine{ihedn-cover}{%
      Times New Roman not found. Fallback to TeX Gyre Termes.\MessageBreak
      Install Times New Roman to match reference metrics exactly%
    }%
    \setmainfont{TeX Gyre Termes}%
    \renewcommand{\CoverFontFallbackNote}{fallback=TeX Gyre Termes (Times New Roman missing)}%
  }%
}
\ifcoverfontglobal
  \CoverSetupMainFont
\fi
\ifcoverglobaltypesetting
  \CoverApplyTypesettingFreeze
\fi

% Times New Roman has no OpenType small-caps feature in this setup.
% Keep fix local by default to avoid changing host document behavior.
\newcommand{\CoverApplySmallCapsFix}{%
  \renewcommand{\textsc}[1]{\MakeUppercase{##1}}%
  \renewcommand{\scshape}{\upshape}%
}
\ifcoverglobalsmallcapsfix
  \PackageWarningNoLine{ihedn-cover}{%
    Option~global-smallcaps-fix~is~intrusive:~it~redefines~\string\textsc\space and
    \string\scshape\space globally.\MessageBreak
    Prefer~local-smallcaps-fix~for~cover-only~scope%
  }%
  \CoverApplySmallCapsFix
\fi

