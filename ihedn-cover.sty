\cs_new:Npn \CoverHeaderTwoField { \tl_use:N \l_cover_header_two_tl }
\cs_new:Npn \CoverHeaderThreeField { \tl_use:N \l_cover_header_three_tl }
\cs_new:Npn \CoverReportLineOneField { \tl_use:N \l_cover_reportline_one_tl }
\cs_new:Npn \CoverReportLineTwoField { \tl_use:N \l_cover_reportline_two_tl }
\cs_new:Npn \CoverTitleFontSpec
