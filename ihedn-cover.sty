\cs_new:Npn \CoverSubtitleFontSpec { \fontsize{20.000pt}{22.000pt}\selectfont }
\cs_new:Npn \CoverCommitteeFontSpec { \fontsize{10.667pt}{12.000pt}\selectfont }
\cs_new_protected:Npn \CoverPlaceLogoIfSet
  {
    \tl_if_blank:VF \l_cover_logo_path_tl
      {
        \tl_set_eq:NN \l_tmpa_tl \l_cover_logo_path_tl
        \tl_set:Nx \l_tmpb_tl { \tl_lower_case:n { \tl_use:N \l_tmpa_tl } }

        \regex_match:nnTF { \.svg\Z } { \l_tmpb_tl }
          {
            \regex_replace_once:nnN { \.[sS][vV][gG]\Z } {} \l_tmpa_tl
            \ifcoverusesvg
              \CoverPlaceSvg{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpa_tl}
            \else
              \tl_set:Nx \l_tmpc_tl { \l_tmpa_tl .pdf }
              \file_if_exist:nTF { \tl_use:N \l_tmpc_tl }
                { \CoverPlaceImage{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpc_tl} }
                {
                  \tl_set:Nx \l_tmpc_tl { \l_tmpa_tl .png }
                  \file_if_exist:nTF { \tl_use:N \l_tmpc_tl }
                    { \CoverPlaceImage{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpc_tl} }
                    {
                      \PackageWarningNoLine{ihedn-cover}
                        {SVG~path~'\l_tmpa_tl.svg'~provided~but~svg~support~is~disabled~
                         and~no~.pdf/.png~fallback~was~found}
                    }
                }
            \fi
          }
          {
            \regex_match:nnTF { \.(pdf|png)\Z } { \l_tmpb_tl }
              {
                \CoverPlaceImage{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpa_tl}
              }
              {
                \tl_set:Nx \l_tmpc_tl { \l_tmpa_tl .pdf }
                \file_if_exist:nTF { \tl_use:N \l_tmpc_tl }
                  { \CoverPlaceImage{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpc_tl} }
                  {
                    \tl_set:Nx \l_tmpc_tl { \l_tmpa_tl .png }
                    \file_if_exist:nTF { \tl_use:N \l_tmpc_tl }
                      { \CoverPlaceImage{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpc_tl} }
                      {
                        \ifcoverusesvg
                          \tl_set:Nx \l_tmpc_tl { \l_tmpa_tl .svg }
                          \file_if_exist:nTF { \tl_use:N \l_tmpc_tl }
                            { \CoverPlaceSvg{\CoverLogoX}{\CoverLogoY}{\CoverLogoWidth}{\CoverLogoHeight}{\l_tmpa_tl} }
                            {
                              \PackageWarningNoLine{ihedn-cover}
                                {Logo~path~'\l_tmpa_tl'~not~found.~Tried~.pdf,~.png,~.svg}
                            }
                        \else
                          \PackageWarningNoLine{ihedn-cover}
                            {Logo~path~'\l_tmpa_tl'~not~found.~Tried~.pdf,~.png~
                             (svg~support~disabled)}
                        \fi
                      }
                  }
              }
          }
      }
  }
